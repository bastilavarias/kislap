---
export const prerender = false;
import Layout from '@/layouts/main.astro';
import { ShowcaseFeed } from '@/components/showcase-feed';

const allowedTypes = new Set(["all", "portfolio", "linktree", "menu"]);
const rawSelectedType = (Astro.url.searchParams.get("type") || "all").toLowerCase();
const selectedType = (allowedTypes.has(rawSelectedType) ? rawSelectedType : "all") as
  | "all"
  | "portfolio"
  | "linktree"
  | "menu";
const apiUrl = new URL(`${import.meta.env.API_URL}/api/projects/list/public`);
apiUrl.searchParams.set("limit", "9");
if (selectedType !== "all") {
  apiUrl.searchParams.set("type", selectedType);
}

let initialProjects = [];

try {
  const response = await fetch(apiUrl);

  if (!response.ok) {
    console.error("API Error:", response.statusText);
  } else {
    const result = await response.json();
    initialProjects = result.data || result;
  }
} catch (error) {
  console.error("Network/Fetch Error:", error);
}

const title = "Kislap - Showcase";
const description = "Explore portfolios, link-in-bio pages, menus, and websites built with Kislap.";

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": initialProjects.map((project: any, index: number) => ({
      "@type": "ListItem",
      "position": index + 1,
      "url": `https://${project.sub_domain}.kislap.app`,
      "name": project.name
    }))
  }
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <section class="relative overflow-hidden pb-32 pt-20">
    <div class="pointer-events-none absolute left-1/2 top-0 h-[500px] w-full max-w-6xl -translate-x-1/2 rounded-full bg-primary/5 opacity-50 blur-[120px]"></div>
    <div class="container relative z-10 mx-auto max-w-6xl px-4">
      <ShowcaseFeed
        client:load
        projects={initialProjects}
        apiBaseUrl={import.meta.env.API_URL}
        initialType={selectedType}
      />
    </div>
  </section>
</Layout>
