---
export const prerender = false;

import { HelpPageContent } from '@/components/help-page-content';
import Layout from '@/layouts/main.astro';
import { CONTACT_EMAIL } from '@/lib/site-config';

const title = 'Help | Kislap';
const description = 'Need help with Kislap? Send a support request and we will route it through our admin inbox.';
---

<Layout title={title} description={description}>
  <HelpPageContent
    client:load
    apiBaseUrl={import.meta.env.API_URL}
    contactEmail={CONTACT_EMAIL}
  />
</Layout>
