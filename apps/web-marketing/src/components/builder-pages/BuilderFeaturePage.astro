---
import { ArrowRight, CheckCircle2, Search, Sparkles } from '@lucide/astro';
import { builderPages, type BuilderFeaturePageConfig } from '@/data/builder-pages';
import { BuilderPageFaq } from '@/components/builder-pages/builder-page-faq';
import { BUILDER_URL, getBuilderProjectCreateUrl, getFeaturePagePath } from '@/lib/site-config';

interface Props {
  page: BuilderFeaturePageConfig;
}

const { page } = Astro.props;
const relatedPages = Object.values(builderPages).filter((entry) => entry.slug !== page.slug);
const builderCreateLink =
  page.slug === 'portfolio-builder'
    ? getBuilderProjectCreateUrl({ type: 'portfolio', starter: 'resume-first' })
    : page.slug === 'linktree-builder'
      ? getBuilderProjectCreateUrl({ type: 'linktree', starter: 'creator' })
      : getBuilderProjectCreateUrl({ type: 'menu', starter: 'cafe' });
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "name": page.title,
      "description": page.description,
      "url": Astro.url.href,
      "keywords": page.keywords.join(", "),
    },
    {
      "@type": "SoftwareApplication",
      "name": `Kislap ${page.eyebrow}`,
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": page.description,
      "url": BUILDER_URL,
    },
    {
      "@type": "FAQPage",
      "mainEntity": page.faq.map((item) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer,
        },
      })),
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Features",
          "item": new URL("/features", Astro.url.origin).toString(),
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": page.eyebrow,
          "item": Astro.url.href,
        },
      ],
    },
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<div class="flex flex-col gap-24 pb-24">
  <section class="relative overflow-hidden px-4 pb-24 pt-16 md:pt-24">
    <div class="pointer-events-none absolute inset-x-0 top-0 mx-auto h-[420px] max-w-6xl rounded-full bg-primary/8 blur-[120px]"></div>
    <div class="container relative z-10 mx-auto grid max-w-6xl gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
      <div class="space-y-8">
        <div class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-2 text-sm font-semibold text-primary">
          <Sparkles class="h-4 w-4" />
          {page.eyebrow}
        </div>

        <div class="space-y-5">
          <h1 class="max-w-4xl text-4xl font-bold tracking-tight text-foreground md:text-6xl">
            {page.heroTitle}
          </h1>
          <p class="max-w-2xl text-xl leading-relaxed text-foreground/80">
            {page.heroLead}
          </p>
          <p class="max-w-2xl text-lg leading-relaxed text-muted-foreground">
            {page.heroBody}
          </p>
        </div>

        <div class="flex flex-col gap-4 sm:flex-row">
          <a
            href={builderCreateLink}
            class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-base font-semibold text-primary-foreground transition hover:translate-y-[-1px] hover:shadow-lg"
          >
            Start building now
            <ArrowRight class="ml-2 h-4 w-4" />
          </a>
          <a
            href="/showcase"
            class="inline-flex items-center justify-center rounded-full border border-border bg-background px-6 py-3 text-base font-semibold text-foreground transition hover:border-primary/40 hover:text-primary"
          >
            Browse live examples
          </a>
        </div>
      </div>

      <div class="relative">
        <div class="relative mx-auto w-full max-w-2xl pb-12 lg:pb-0">
          <div class="overflow-hidden shadow-2xl shadow-primary/10">
            <img
              src={page.image}
              alt={`${page.eyebrow} builder preview`}
              class="h-[420px] w-full object-cover object-top"
              loading="eager"
            />
          </div>
          <div class="absolute -bottom-10 right-0 w-[46%] overflow-hidden border-8 border-background bg-background shadow-[0_18px_50px_rgba(15,23,42,0.18)] dark:border-zinc-950 dark:bg-zinc-950">
            <img
              src={page.templateImage}
              alt={`${page.eyebrow} template preview`}
              class="h-[240px] w-full object-cover object-top"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container mx-auto max-w-6xl px-4">
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div class="space-y-5">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Who it is for</p>
        <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
          {page.audienceTitle}
        </h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {page.audience.map((entry) => (
          <div class="rounded-2xl border border-border/70 bg-card p-5">
            <div class="flex gap-3">
              <CheckCircle2 class="mt-0.5 h-5 w-5 shrink-0 text-primary" />
              <p class="text-base leading-relaxed text-foreground/85">{entry}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="container mx-auto max-w-6xl px-4">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">
        {page.featureTitle}
      </p>
      <h2 class="mt-4 text-3xl font-bold tracking-tight text-foreground md:text-4xl">
        {page.featureLead}
      </h2>
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {page.features.map((feature) => (
        <div class="rounded-[1.75rem] border border-border bg-card p-8 shadow-sm">
          <h3 class="text-2xl font-bold tracking-tight text-foreground">{feature.title}</h3>
          <p class="mt-4 text-base leading-relaxed text-muted-foreground">
            {feature.description}
          </p>
          <ul class="mt-6 space-y-3">
            {feature.bullets.map((bullet) => (
              <li class="flex gap-3 text-sm leading-relaxed text-foreground/80">
                <CheckCircle2 class="mt-0.5 h-4 w-4 shrink-0 text-primary" />
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="container mx-auto max-w-6xl px-4">
    <div class="rounded-[2rem] border border-border bg-card/70 p-8 md:p-10">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">
          {page.workflowTitle}
        </p>
        <h2 class="mt-4 text-3xl font-bold tracking-tight text-foreground md:text-4xl">
          A simple publishing workflow that gets you to a live page faster.
        </h2>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {page.workflow.map((item) => (
          <div class="rounded-2xl border border-border/70 bg-background p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-primary">{item.step}</p>
            <h3 class="mt-3 text-xl font-bold text-foreground">{item.title}</h3>
            <p class="mt-3 text-base leading-relaxed text-muted-foreground">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="container mx-auto max-w-6xl px-4">
    <div class="grid gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
      <div class="space-y-8">
        <p class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-2 text-sm font-semibold text-primary">
          <Search class="h-4 w-4" />
          SEO-friendly by design
        </p>
        <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
          Built to be understood by people, search engines, and AI tools.
        </h2>
        <p class="text-lg leading-relaxed text-muted-foreground">
          These builder pages do more than look polished. They give each product a focused search
          presence, clearer positioning, and stronger machine-readable context for discovery.
        </p>

        <div class="grid gap-4">
          {[
            {
              title: "Search intent aligned copy",
              description:
                "Each page is written around what people are actually searching for, so the message stays relevant from headline to FAQ.",
            },
            {
              title: "Stronger social and Google previews",
              description:
                "Titles, descriptions, and page structure are shaped to communicate the product clearly when shared or indexed.",
            },
            {
              title: "Cleaner AI and crawler context",
              description:
                "Structured layout, focused sections, and internal linking make it easier for AI tools and crawlers to interpret the page accurately.",
            },
          ].map((item) => (
            <div class="border-l-2 border-primary/20 pl-4">
              <h3 class="text-base font-semibold text-foreground">{item.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                {item.description}
              </p>
            </div>
          ))}
        </div>
      </div>

      <div class="relative overflow-hidden border border-border/70 bg-card/60 p-6 backdrop-blur">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(59,130,246,0.12),transparent_35%),radial-gradient(circle_at_bottom_left,rgba(236,72,153,0.10),transparent_35%)]" />
        <div class="relative">
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-primary">
            Search themes
          </p>
          <h3 class="mt-3 text-2xl font-bold tracking-tight text-foreground">
            The kind of intent these pages are built to capture.
          </h3>
          <p class="mt-3 max-w-xl text-sm leading-relaxed text-muted-foreground">
            Instead of acting like generic product pages, each builder page targets a focused set
            of discovery phrases that support search, sharing, and internal navigation.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            {page.keywords.map((keyword, index) => (
              <div
                class:list={[
                  "inline-flex items-center rounded-full px-4 py-2 text-sm font-medium shadow-sm",
                  index % 3 === 0 && "bg-primary text-primary-foreground",
                  index % 3 === 1 && "border border-border bg-background text-foreground",
                  index % 3 === 2 && "bg-secondary text-secondary-foreground",
                ]}
              >
                {keyword}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container mx-auto max-w-5xl px-4">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">FAQ</p>
      <h2 class="mt-4 text-3xl font-bold tracking-tight text-foreground md:text-4xl">
        Answers to the questions people usually ask before they commit.
      </h2>
    </div>

    <BuilderPageFaq client:load items={page.faq} slug={page.slug} />
  </section>

  <section class="container mx-auto max-w-5xl px-4">
    <div class="rounded-[2.5rem] bg-primary px-6 py-16 text-center text-primary-foreground md:px-16 md:py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary-foreground/80">
        Ready to publish
      </p>
      <h2 class="mt-4 text-3xl font-bold tracking-tight md:text-5xl">
        Start building with Kislap and turn your content into a live page faster.
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-primary-foreground/85">
        You do not need a complicated design process to ship something credible. Start with the builder,
        pick the direction you need, and publish when it feels right.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={builderCreateLink}
          class="inline-flex items-center justify-center rounded-full bg-background px-6 py-3 text-base font-semibold text-foreground transition hover:translate-y-[-1px] hover:shadow-lg"
        >
          Open the builder
          <ArrowRight class="ml-2 h-4 w-4" />
        </a>
        <a
          href="/showcase"
          class="inline-flex items-center justify-center rounded-full border border-primary-foreground/30 px-6 py-3 text-base font-semibold text-primary-foreground transition hover:bg-primary-foreground/10"
        >
          See live examples
        </a>
      </div>
    </div>
  </section>

  <section class="container mx-auto max-w-6xl px-4">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Explore more builders</p>
        <h2 class="mt-4 text-3xl font-bold tracking-tight text-foreground md:text-4xl">
          See how the other Kislap builders are positioned.
        </h2>
      </div>
      <p class="max-w-xl text-base leading-relaxed text-muted-foreground">
        These pages work together. If someone is comparing portfolio sites, link-in-bio pages, and menus,
        this gives them a clean path deeper into the product instead of dropping them back at the homepage.
      </p>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {relatedPages.map((entry) => (
        <a
          href={getFeaturePagePath(entry.slug)}
          class="group rounded-[1.75rem] border border-border bg-card p-8 transition hover:border-primary/40 hover:shadow-lg"
        >
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">{entry.eyebrow}</p>
          <h3 class="mt-3 text-2xl font-bold tracking-tight text-foreground group-hover:text-primary">
            {entry.heroTitle}
          </h3>
          <p class="mt-4 text-base leading-relaxed text-muted-foreground">{entry.description}</p>
          <span class="mt-6 inline-flex items-center text-sm font-semibold text-primary">
            Explore this builder
            <ArrowRight class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1" />
          </span>
        </a>
      ))}
    </div>
  </section>
</div>
